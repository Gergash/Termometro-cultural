# Termómetro Cultural - Environment variables
# Copy to .env and fill values

# App
APP_ENV=development
APP_NAME=termometro-cultural
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/termometro_cultural
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/termometro_cultural

# Redis (optional - queue / cache)
REDIS_URL=redis://localhost:6379/0
USE_REDIS_QUEUE=false

# NLP - OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# NLP - Grok (alternative)
GROK_API_KEY=
GROK_MODEL=grok-2

# Scraping
PLAYWRIGHT_HEADLESS=true
PROXY_ROTATION=false
# PROXY_LIST=http://user:pass@host:port,...
PROXY_LIST=

# Apify (optional)
# APIFY_API_TOKEN=...

# Municipality context (Tuluá)
MUNICIPALITY_NAME=Tuluá
MUNICIPALITY_REGION=Valle del Cauca
TIMEZONE=America/Bogota
